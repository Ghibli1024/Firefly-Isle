VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_EDGE_FUNCTION_URL=https://your-project.functions.supabase.co
VITE_SUPABASE_WECHAT_PROVIDER=custom:wechat

# Supabase Edge Function secrets/env, configured server-side rather than exposed to Vite.
# Keep DEFAULT_LLM_PROVIDER=gemini until DeepSeek has passed live verification.
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key
DEFAULT_DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
